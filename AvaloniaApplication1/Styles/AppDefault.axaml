<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cc="clr-namespace:AvaloniaApplication1.Controls">
  <Design.PreviewWith>
    <Border Padding="20" Background="{DynamicResource PrimaryBackgroundGradient}" Width="200">
      <!-- Add Controls for Previewer Here -->
      <Button Content="Hello"></Button>
    </Border>
  </Design.PreviewWith>
  
  <!--<Style Selector="StackPanel.form">
    <Setter Property="Margin" Value="15"/>
    
    <Style Selector="^ cc|Section">
      <Setter Property="Margin" Value="0 8 0 2"/>    
    </Style>
    <Style Selector="^ TextBox,ComboBox,CheckBox">
      <Setter Property="Margin" Value="0 0 0 16"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="^ TextBlock"> 
      <Setter Property="Margin" Value="0,0,0,4"/> 
    </Style>
  </Style>-->
  
  <Style Selector="TextBlock.h1">
    <Setter Property="FontSize" Value="18"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>
  
  <Style Selector="TextBox.h1">
    <Setter Property="FontSize" Value="18"/>
  </Style>
  
  <Style Selector="TextBlock.h2">
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>
  
  <Style Selector="TextBlock.subh2">
    <Setter Property="Opacity" Value="0.7"/>
  </Style>
  
  <Style Selector="Button.action">
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Padding" Value="4"/>
    <Setter Property="Height" Value="36"/>
  </Style>
  
  <!-- <Style Selector="Button.primary"> -->
  <!--   <Setter Property="Background" Value="#4CAF50"/> -->
  <!--   <Setter Property="Foreground" Value="White"/> -->
  <!--   <Setter Property="Padding" Value="8"/> -->
  <!-- </Style> -->
  <!-- -->
  <!-- <Style Selector="Button.primary:pointerover /template/ ContentPresenter"> -->
  <!--   <Setter Property="Background" Value="#43A047"/> -->
  <!-- </Style> -->
  <!-- -->
  <!-- <Style Selector="Button.primary:pressed /template/ ContentPresenter"> -->
  <!--   <Setter Property="Background" Value="#388E3C"/> -->
  <!-- </Style> -->
  
  <Style Selector="WrapPanel.table-actions">
    <Setter Property="Orientation" Value="Horizontal"/>
    <Setter Property="Margin" Value="5"/>
            
    <Style Selector="^ Button">
      <Setter Property="Width" Value="105"/>
      <!-- <Setter Property="Margin" Value="0 0 5 0"/> -->
      
      <Style Selector="^ > Grid">
        <Style Selector="^ > Image">
          <Setter Property="VerticalAlignment" Value="Center"/>
          <Setter Property="Margin" Value="0 5 0 0"/>
          <Setter Property="Height" Value="30"/>
        </Style>                
        <Style Selector="^ > TextBlock">
          <Setter Property="VerticalAlignment" Value="Center"/>
          <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
      </Style>
    </Style>
  </Style>
</Styles>
