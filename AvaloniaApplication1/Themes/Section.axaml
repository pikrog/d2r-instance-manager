<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cc="using:AvaloniaApplication1.Controls">
    <Design.PreviewWith>
        <Border Padding="20">
            <cc:Section Title="Test section">
                <TextBlock>Text under the section</TextBlock>
            </cc:Section>
        </Border>
    </Design.PreviewWith>

    <Style Selector="cc|Section">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cc:Section}">
                    <StackPanel Margin="0 8 0 0">
                        <Border Height="1" Background="{DynamicResource SectionUnderlineBrush}" Margin="0,0,0,12"/> <!--color theme variants...-->
                        <TextBlock Classes="h2" Margin="0,0,0,8" Text="{TemplateBinding Title}"/>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                     </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</Styles>
