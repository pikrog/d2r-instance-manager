<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:AvaloniaApplication1.ViewModels"
             xmlns:services="using:AvaloniaApplication1.Services"
             xmlns:designViewModels="using:AvaloniaApplication1.Design.ViewModels"
             xmlns:controls="using:AvaloniaApplication1.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaApplication1.Views.RegionsPageView"
             x:DataType="viewModels:RegionsPageViewModel"
             services:DialogService.Register="{Binding}">
     <Design.DataContext>
        <designViewModels:RegionsPageDesignViewModel/>
    </Design.DataContext>
    
    <UserControl.Styles>
        <Style Selector="Border.dimmed">
            <Setter Property="Opacity" Value="0.25"/>
        </Style>
        
        <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <!--<Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />-->
        </Style>
        
        <Style Selector="DataValidationErrors">
            <Setter Property="Template">
                <ControlTemplate>
                    <DockPanel LastChildFill="True">
                    <ContentControl DockPanel.Dock="Right"
                                    ContentTemplate="{TemplateBinding ErrorTemplate}"
                                    DataContext="{TemplateBinding Owner}"
                                    Content="{Binding (DataValidationErrors.Errors)}"
                                    IsVisible="{Binding (DataValidationErrors.HasErrors)}"/>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Content="{TemplateBinding Content}"
                                      Padding="{TemplateBinding Padding}"/>
                    </DockPanel>
                </ControlTemplate>
            </Setter>
            <Setter Property="ErrorTemplate">
                <DataTemplate x:DataType="{x:Type x:Object}">
                    <Border Width="14" Height="14" Margin="4 0 1 0" 
                            Background="Transparent">
                        <Border.Styles>
                            <Style Selector="ToolTip">
                                <Setter Property="Background" Value="LightCoral"/>
                                <Setter Property="BorderBrush" Value="Red"/>
                            </Style>
                        </Border.Styles>
                        <ToolTip.Tip>
                            <ItemsControl ItemsSource="{Binding}"/>
                        </ToolTip.Tip>
                        <Path Data="{StaticResource ErrorGeometry}"
                              Stroke="Red" 
                              StrokeThickness="2"/>
                    </Border>
                </DataTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>
    
    <Grid>
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Regions}">
                <ItemsControl.Template>
                    <ControlTemplate>
                        <StackPanel Orientation="Vertical">
                            <ItemsPresenter/>
                            <Border Height="135" CornerRadius="10" BoxShadow="0 1 3 0 #80000000" Margin="20 10 20 10"
                                    Classes.dimmed="{Binding EditedCard, Converter = {x:Static ObjectConverters.IsNotNull}}">
                                <Border.Styles>
                                    <Style Selector="Button:pressed">
                                        <Setter Property="RenderTransform" Value="{x:Null}"/>
                                    </Style>
                                    
                                </Border.Styles>
                                <Button VerticalAlignment="Stretch" HorizontalAlignment="Stretch" CornerRadius="10" BorderThickness="0"
                                        Background="Transparent" Padding="0 24" HorizontalContentAlignment="Center"
                                        Command="{Binding NewRegionCommand}">
                                    <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="8" Opacity="0.60">
                                        <Image Grid.Column="0" VerticalAlignment="Center" Source="{SvgImage /Assets/images/add.svg}" Width="32" Height="32"/>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center">Add</TextBlock>
                                    </Grid>
                                </Button>
                            </Border>
                        </StackPanel>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Height="135" Padding="10" Margin="20 10 20 0" CornerRadius="10" BoxShadow="0 1 3 0 #80000000">
                            <Classes.dimmed>
                                <MultiBinding Converter="{StaticResource ReferenceNotNullAndNotEqualsConverter}" ConverterParameter="dimmed">
                                    <Binding Path="$parent[ItemsControl].((viewModels:RegionsPageViewModel)DataContext).EditedCard"/>
                                    <Binding/>
                                </MultiBinding>
                            </Classes.dimmed>
                            
                            <Grid>
                                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto" RowSpacing="10" ColumnSpacing="16" 
                                      Margin="0 12"
                                      IsVisible="{Binding EditForm,Converter={x:Static ObjectConverters.IsNull}}">
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Classes="h2" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Name}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Classes="subh2" VerticalAlignment="Center" Text="{Binding Address}"/>
                                    <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.60">
                                        <Button Classes="action"
                                                Command="{Binding $parent[UserControl].((viewModels:RegionsPageViewModel)DataContext).EditRegionCommand}"
                                                CommandParameter="{Binding}">
                                            <Image Source="{SvgImage /Assets/images/edit.svg}"/>
                                        </Button>                                
                                        <Button Classes="action"
                                                Command="{Binding $parent[UserControl].((viewModels:RegionsPageViewModel)DataContext).DeleteRegionCommand}"
                                                CommandParameter="{Binding}">
                                            <Image Source="{SvgImage /Assets/images/delete.svg}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                
                                <ContentControl IsVisible="{Binding EditForm,Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="12" ColumnSpacing="16"
                                          DataContext="{Binding EditForm}">
                                        
                                        <controls:FormField Grid.Row="0" Grid.Column="0" Label="Name" Text="{Binding Name}"/>
                                        <controls:FormField Grid.Row="1" Grid.Column="0" Label="Address" Text="{Binding Address}"/>
                                        
                                        <!--<StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock FontSize="12" Text="Name"/>
                                        <TextBox VerticalAlignment="Center" FontWeight="Bold" Text="{Binding Name}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Margin="0 8 0 0" FontSize="12" Text="Address"/>
                                        <TextBox VerticalAlignment="Center" Text="{Binding Address}"/>
                                        </StackPanel>-->
                                        
                                        <!-- todo: fix button pos, should be centered on card, not the grid -->
                                        <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" 
                                                    Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Classes="action"
                                                    Command="{Binding $parent[UserControl].((viewModels:RegionsPageViewModel)DataContext).SaveRegionCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsDefault="True">
                                                <Image Source="{SvgImage /Assets/images/accept.svg}"/>
                                            </Button>                                
                                            <Button Classes="action"
                                                    Command="{Binding $parent[UserControl].((viewModels:RegionsPageViewModel)DataContext).EndEditCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsCancel="True">
                                                <Image Source="{SvgImage /Assets/images/discard.svg}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </ContentControl>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
