<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="220"
        Width="300" Height="220"
        WindowStartupLocation="CenterScreen"
        x:Class="AvaloniaApplication1.Views.InitialWindow"
        Title="D2R Profile Manager - Loading"
        CanResize="False" CanMinimize="False" CanMaximize="False"
        WindowDecorations="BorderOnly">
    <DockPanel>
        <!-- <TextBlock>Loading</TextBlock> -->
        <ProgressBar DockPanel.Dock="Bottom" IsIndeterminate="True"/>
        <Grid>
            <Image Source="/Assets/images/barb-bo.bmp" Stretch="None" HorizontalAlignment="Center"/>
        </Grid>
    </DockPanel>
</Window>
